{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": true,
  "functions": {
    "api/admin/*.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/bio", "destination": "/about", "permanent": true },
    { "source": "/bio/", "destination": "/about/", "permanent": true },
    { "source": "/contacto", "destination": "/contact", "permanent": true },
    { "source": "/contacto/", "destination": "/contact/", "permanent": true },
    { "source": "/galeria", "destination": "/works", "permanent": true },
    { "source": "/galeria/", "destination": "/works/", "permanent": true },
    { "source": "/galeria/canvas", "destination": "/works?filter=canvas", "permanent": true },
    { "source": "/galeria/canvas/", "destination": "/works/?filter=canvas", "permanent": true },
    { "source": "/galeria/graffiti", "destination": "/works?filter=graffiti", "permanent": true },
    { "source": "/galeria/graffiti/", "destination": "/works/?filter=graffiti", "permanent": true },
    { "source": "/galeria/vr-art", "destination": "/vr-art", "permanent": true },
    { "source": "/galeria/vr-art/", "destination": "/vr-art/", "permanent": true },
    { "source": "/galeria/murales", "destination": "/murals", "permanent": true },
    { "source": "/galeria/murales/", "destination": "/murals/", "permanent": true },
    { "source": "/shop", "destination": "/available-works", "permanent": true },
    { "source": "/shop/", "destination": "/available-works/", "permanent": true },
    { "source": "/home-2", "destination": "/", "permanent": true },
    { "source": "/home-2/", "destination": "/", "permanent": true },
    { "source": "/aviso-legal", "destination": "/privacy-policy", "permanent": true },
    { "source": "/aviso-legal/", "destination": "/privacy-policy/", "permanent": true },
    { "source": "/terminos-y-condiciones", "destination": "/privacy-policy", "permanent": true },
    { "source": "/terminos-y-condiciones/", "destination": "/privacy-policy/", "permanent": true },
    { "source": "/politica-de-cookies", "destination": "/privacy-policy", "permanent": true },
    { "source": "/politica-de-cookies/", "destination": "/privacy-policy/", "permanent": true },
    { "source": "/devoluciones-y-reembolso", "destination": "/privacy-policy", "permanent": true },
    { "source": "/devoluciones-y-reembolso/", "destination": "/privacy-policy/", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy-policy/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
