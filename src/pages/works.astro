---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import FilterBar from "../components/FilterBar.astro";
import { works, pages } from "../lib/content";

const page = pages.works;
const filters = [
  { label: "All", value: "all" },
  { label: "Canvas", value: "canvas" },
  { label: "Graffiti", value: "graffiti" },
  { label: "Murals", value: "murals" },
  { label: "VR Art", value: "vr-art" },
  { label: "Available", value: "available" },
  { label: "Sold", value: "sold" }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Abstract Graffiti Paintings by Hize",
  url: "https://hizeart.vercel.app/works/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro page-intro--center page-intro--display">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
    <FilterBar filters={filters} />
  </section>

  <section class="page-shell section" style="padding-top: 0;">
    <div class="work-grid">
      {works.map((work) => <WorkCard work={work} showDetails />)}
    </div>
  </section>
</BaseLayout>
