---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import FilterBar from "../components/FilterBar.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { worksCatalog, pages } from "../lib/content";
import { absoluteUrl, getLocalizedPageContent, getUiText, resolveLocale } from "../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("works", pages.works, locale);
const ui = getUiText(locale);
const filters = [
  { label: locale === "es" ? "Canvas" : "Canvas", value: "canvas" },
  { label: locale === "es" ? "Murales" : "Murals", value: "murals" },
  { label: "Graffiti", value: "graffiti" },
  { label: locale === "es" ? "Disponible" : "Available", value: "available" },
  { label: locale === "es" ? "Vendido" : "Sold", value: "sold" }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "es" ? "Pinturas de graffiti abstracto de Hize" : "Abstract Graffiti Paintings by Hize",
  url: absoluteUrl(locale === "es" ? "/es/works/" : "/works/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro page-intro--center page-intro--display">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
    <FilterBar filters={filters} defaultFilter="canvas" locale={locale} />
  </section>

  <section class="page-shell section" style="padding-top: 0;">
    <div class="work-grid" data-live-collection="works" data-live-item-type="work" data-live-show-details="true" data-live-cta-label={ui.common.viewWork} data-live-include-murals="true">
      {worksCatalog.map((work) => <WorkCard work={work} showDetails locale={locale} ctaLabel={ui.common.viewWork} />)}
    </div>
  </section>

  <CollectionLiveSync />
</BaseLayout>
