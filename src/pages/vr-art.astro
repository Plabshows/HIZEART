---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import ImageGrid from "../components/ImageGrid.astro";
import CTASection from "../components/CTASection.astro";
import { pages } from "../lib/content";

const page = pages.vrArt;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: "VR Art by Hize",
  url: "https://hizeart.vercel.app/vr-art/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="editorial-hero">
    <h1>{page.heroTitle}</h1>
    <div class="editorial-hero__media" style="margin-top: 3rem;">
      <ResponsiveImage
        src={page.heroImage}
        alt={page.heroAlt}
        loading="eager"
        sizes="100vw"
      />
    </div>
  </section>

  <section class="section">
    <div class="editorial-grid">
      <div style="grid-column: span 3;">
        <p class="eyebrow" style="border-top: 1px solid var(--primary); padding-top: 1rem;">{page.introEyebrow}</p>
      </div>
      <div style="grid-column: span 7;">
        <p class="lead">{page.introLead}</p>
        <p>{page.introText}</p>
      </div>
    </div>
  </section>

  <section class="section--dark">
    <div class="section-heading">
      <h2>{page.disciplinesTitle}</h2>
    </div>
    <div class="path-grid">
      {page.disciplines.map((discipline: { eyebrow: string; title: string; text: string }) => (
        <article class="info-card">
          <p class="eyebrow">{discipline.eyebrow}</p>
          <h3>{discipline.title}</h3>
          <p>{discipline.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-heading">
        <h2>{page.visualsTitle}</h2>
        <span class="eyebrow">{page.visualsCounter}</span>
      </div>
      <ImageGrid images={page.visuals} />
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    text={page.cta.text}
    buttons={[
      { href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel },
      { href: page.cta.secondaryButtonHref, label: page.cta.secondaryButtonLabel, variant: "secondary" }
    ]}
  />
</BaseLayout>
