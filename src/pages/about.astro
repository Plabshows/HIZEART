---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CTASection from "../components/CTASection.astro";
import { exhibitions, pages } from "../lib/content";

const page = pages.about;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Manuel Forner Hize",
  alternateName: "Hize",
  jobTitle: "Spanish contemporary urban artist",
  url: "https://hizeart.vercel.app/about/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="section split-section">
    <div>
      <ResponsiveImage src={page.portraitImage} alt={page.portraitAlt} loading="eager" />
      <p class="meta-line" style="margin-top: 1rem;"><span>{page.metaOne}</span><span>{page.metaTwo}</span></p>
    </div>
    <div>
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      {page.paragraphs.map((paragraph: string) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="about-quote">
    <h2>{page.quote}</h2>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{page.exhibitionsEyebrow}</p>
        <h2>{page.exhibitionsTitle}</h2>
      </div>
      <a class="text-link" href="/exhibitions/">{page.exhibitionsLinkLabel}</a>
    </div>
    <div class="timeline">
      {exhibitions.slice(0, 6).map((entry) => (
        <article class="timeline-item">
          <time>{entry.year}</time>
          <div>
            <h3>{entry.title}</h3>
            <p>{entry.type} / {entry.location}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="feature-band">
    <div class="page-shell split-section">
      <div>
        <p class="eyebrow">{page.collaborationsEyebrow}</p>
        <h2 set:html={page.collaborationsTitle.replace(/\n/g, "<br />")} />
      </div>
      <div>
        <p class="lead">{page.portfolioText}</p>
        <div class="button-row">
          <a class="button" href={page.portfolioButtonHref}>{page.portfolioButtonLabel}</a>
          <a class="button button--primary" href={page.contactButtonHref}>{page.contactButtonLabel}</a>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    text={page.cta.text}
    buttons={[{ href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel }]}
  />
</BaseLayout>
