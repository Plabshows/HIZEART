---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import CTASection from "../components/CTASection.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { works, pages } from "../lib/content";

const page = pages.availableWorks;
const availableWorks = works.filter((work) => work.availability === "Available");
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Available Artworks by Hize",
  url: "https://hizeart.vercel.app/available-works/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
    <div class="note-bar">
      <span>{page.noteOne}</span>
      <span>{page.noteTwo}</span>
    </div>
  </section>

  <section class="page-shell section" style="padding-top: 0;">
    <div class="work-grid" data-live-collection="works" data-live-item-type="work" data-live-show-details="true" data-live-cta-label="Enquire about this work" data-live-available-only="true">
      {availableWorks.map((work) => <WorkCard work={work} showDetails ctaLabel="Enquire about this work" />)}
    </div>
    <div class="stats-grid" style="margin-top: 2rem;">
      {page.infoCards.map((card: { title: string; text: string }) => (
        <article class="info-card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    text={page.cta.text}
    buttons={[
      { href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel },
      { href: page.cta.secondaryButtonHref, label: page.cta.secondaryButtonLabel, variant: "secondary" }
    ]}
  />

  <CollectionLiveSync />
</BaseLayout>
