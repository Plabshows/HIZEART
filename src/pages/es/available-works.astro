---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import CTASection from "../../components/CTASection.astro";
import CollectionLiveSync from "../../components/CollectionLiveSync.astro";
import { works, pages } from "../../lib/content";
import { absoluteUrl, getLocalizedPageContent, getUiText, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("availableWorks", pages.availableWorks, locale);
const ui = getUiText(locale);
const availableWorks = works.filter((work) => work.availability === "Available");
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "es" ? "Obras disponibles de Hize" : "Available Artworks by Hize",
  url: absoluteUrl(locale === "es" ? "/es/available-works/" : "/available-works/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
    <div class="note-bar">
      <span>{page.noteOne}</span>
      <span>{page.noteTwo}</span>
    </div>
  </section>

  <section class="page-shell section" style="padding-top: 0;">
    <div class="work-grid" data-live-collection="works" data-live-item-type="work" data-live-show-details="true" data-live-cta-label={ui.common.enquireWork} data-live-available-only="true">
      {availableWorks.map((work) => <WorkCard work={work} showDetails ctaLabel={ui.common.enquireWork} locale={locale} />)}
    </div>
    <div class="stats-grid" style="margin-top: 2rem;">
      {page.infoCards.map((card: { title: string; text: string }) => (
        <article class="info-card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    locale={locale}
    title={page.cta.title}
    text={page.cta.text}
    buttons={[
      { href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel },
      { href: page.cta.secondaryButtonHref, label: page.cta.secondaryButtonLabel, variant: "secondary" }
    ]}
  />

  <CollectionLiveSync />
</BaseLayout>
