---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { pages } from "../../lib/content";
import { absoluteUrl, getLocalizedPageContent, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("contact", pages.contact, locale);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: locale === "es" ? "Contactar con Hize" : "Contact Hize",
  url: absoluteUrl(locale === "es" ? "/es/contact/" : "/contact/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
  </section>

  <section class="page-shell section split-section">
    <div>
      <div class="path-grid" style="grid-template-columns: 1fr;">
        {page.paths.map((path: { eyebrow: string; title: string; text: string }) => (
          <article class="info-card">
            <p class="eyebrow">{path.eyebrow}</p>
            <h3>{path.title === "info@hizeart.com" ? <a href="mailto:info@hizeart.com">{path.title}</a> : path.title}</h3>
            <p>{path.text}</p>
          </article>
        ))}
      </div>
    </div>
    <ContactForm locale={locale} />
  </section>
</BaseLayout>
