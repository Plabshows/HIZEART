---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArtworkDetail from "../../../components/ArtworkDetail.astro";
import { workDetailItems, slugifySegment } from "../../../lib/content";
import { getUiText, resolveLocale } from "../../../lib/i18n";

export function getStaticPaths() {
  return workDetailItems.map((work) => ({
    params: { id: work.slug || slugifySegment(work.id || work.title || "work") },
    props: { work }
  }));
}

const { work } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
const ui = getUiText(locale);
const workImage = new URL(work.image, "https://hizeart.vercel.app").toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: work.title,
  creator: "Manuel Forner Hize",
  artMedium: work.technique,
  image: workImage,
  description: work.description
};
---

<BaseLayout
  title={`${work.title} | ${locale === "es" ? "Obra de Hize" : "Hize Artwork"}`}
  description={work.description}
  image={work.image}
  type="article"
  structuredData={structuredData}
>
  <ArtworkDetail item={work} backHref="/works/" backLabel={ui.common.backToWorks} locale={locale} />
</BaseLayout>
