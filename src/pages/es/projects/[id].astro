---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../../components/ResponsiveImage.astro";
import ImageGrid from "../../../components/ImageGrid.astro";
import CTASection from "../../../components/CTASection.astro";
import { projects, slugifySegment } from "../../../lib/content";
import { getUiText, localizePath, localizeProjectTypeLabel, resolveLocale } from "../../../lib/i18n";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.slug || slugifySegment(project.id || project.title || "project") },
    props: { project }
  }));
}

const { project } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
const ui = getUiText(locale);
const gallery = project.gallery.map((src) => ({ src, alt: project.alt }));
const projectImage = new URL(project.mainImage, "https://hizeart.vercel.app").toString();
const projectVideo = project.video?.youtubeId
  ? {
      title: project.video.title || `${project.title} Film`,
      text: project.video.text || ui.common.projectFilmFallback,
      youtubeUrl: `https://www.youtube-nocookie.com/embed/${project.video.youtubeId}?rel=0&modestbranding=1&playsinline=1`,
      watchUrl: `https://www.youtube.com/watch?v=${project.video.youtubeId}`
    }
  : null;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.title,
  creator: "Manuel Forner Hize",
  locationCreated: project.location,
  image: projectImage,
  description: project.description
};
---

<BaseLayout
  title={`${project.title} | ${locale === "es" ? "Proyecto de Hize" : "Hize Project"}`}
  description={project.description}
  image={project.mainImage}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={project.mainImage} alt={project.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href={localizePath("/projects/", locale)}>{ui.common.backToProjects}</a>
      <p class="eyebrow">{localizeProjectTypeLabel(project.type, locale)}</p>
      <h1>{project.title}</h1>
      <p class="lead">{project.description}</p>
      <dl class="spec-list">
        <div><dt>{ui.common.year}</dt><dd>{project.year}</dd></div>
        <div><dt>{ui.common.location}</dt><dd>{project.location}</dd></div>
        <div><dt>{ui.common.type}</dt><dd>{localizeProjectTypeLabel(project.type, locale)}</dd></div>
        <div><dt>{ui.common.client}</dt><dd>{project.client}</dd></div>
      </dl>
      <div class="button-row">
        <a class="button button--primary" href={localizePath("/contact/", locale)}>{ui.common.startProject}</a>
      </div>
    </div>
  </article>

  {projectVideo && (
    <section class="section project-film">
      <div class="page-shell">
        <div class="section-heading">
          <div>
            <p class="eyebrow">{ui.common.projectFilm}</p>
            <h2>{projectVideo.title}</h2>
          </div>
          <a class="text-link" href={projectVideo.watchUrl} target="_blank" rel="noreferrer">{ui.common.watchOnYouTube}</a>
        </div>
        <div class="project-film__layout">
          <div class="project-film__copy">
            <p class="lead">{projectVideo.text}</p>
            <p class="project-film__meta">{project.title} / {project.location} / {project.year}</p>
          </div>
          <div class="project-film__frame">
            <iframe
              src={projectVideo.youtubeUrl}
              title={`${project.title} on YouTube`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{ui.common.projectVisuals}</p>
          <h2>{project.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} locale={locale} />
    </section>
  )}

  <CTASection
    locale={locale}
    title="Inicia un encargo o colaboración."
    text="Comparte el contexto, la ubicación, el calendario y los objetivos para un mural, obra, activación de marca o experiencia visual inmersiva."
    buttons={[{ href: "/contact/", label: ui.common.contactArtist }]}
  />
</BaseLayout>
