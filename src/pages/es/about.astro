---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import CTASection from "../../components/CTASection.astro";
import CollectionLiveSync from "../../components/CollectionLiveSync.astro";
import { exhibitions, pages, collaborations } from "../../lib/content";
import { absoluteUrl, getLocalizedPageContent, localizePath, localizeProjectTypeLabel, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("about", pages.about, locale);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Manuel Forner Hize",
  alternateName: "Hize",
  jobTitle: "Spanish contemporary urban artist",
  url: absoluteUrl(locale === "es" ? "/es/about/" : "/about/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="section split-section">
    <div>
      <ResponsiveImage src={page.portraitImage} alt={page.portraitAlt} loading="eager" />
      <p class="meta-line" style="margin-top: 1rem;"><span>{page.metaOne}</span><span>{page.metaTwo}</span></p>
    </div>
    <div>
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      {page.paragraphs.map((paragraph: string) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="about-quote">
    <h2>{page.quote}</h2>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{page.exhibitionsEyebrow}</p>
        <h2>{page.exhibitionsTitle}</h2>
      </div>
      <a class="text-link" href={localizePath("/exhibitions/", locale)}>{page.exhibitionsLinkLabel}</a>
    </div>
    <div class="timeline">
      {exhibitions.slice(0, 6).map((entry) => (
        <article class="timeline-item">
          <time>{entry.year}</time>
          <div>
            <h3>{entry.title}</h3>
            <p>{entry.type} / {entry.location}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="feature-band">
    <div class="page-shell split-section">
      <div>
        <p class="eyebrow">{page.collaborationsEyebrow}</p>
        <div class="about-collaboration-list" data-live-collection="collaborations" data-live-item-type="collaboration" data-live-layout="about-collaboration-list">
          {collaborations.map((item) => (
            <article class="about-collaboration-item">
              <h3>{item.name}</h3>
              <p>{localizeProjectTypeLabel(item.type, locale)}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <p class="lead">{page.portfolioText}</p>
        <div class="button-row">
          <a class="button" href={page.portfolioButtonHref}>{page.portfolioButtonLabel}</a>
          <a class="button button--primary" href={page.contactButtonHref}>{page.contactButtonLabel}</a>
        </div>
      </div>
    </div>
  </section>

  <CollectionLiveSync />

  <CTASection
    locale={locale}
    title={page.cta.title}
    text={page.cta.text}
    buttons={[{ href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel }]}
  />
</BaseLayout>
