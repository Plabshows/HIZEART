---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExhibitionTimeline from "../../components/ExhibitionTimeline.astro";
import { exhibitions, pages } from "../../lib/content";
import { absoluteUrl, getLocalizedPageContent, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("exhibitions", pages.exhibitions, locale);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "es" ? "Exposiciones y colaboraciones de Hize" : "Exhibitions and Collaborations by Hize",
  url: absoluteUrl(locale === "es" ? "/es/exhibitions/" : "/exhibitions/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
  </section>
  <section class="page-shell section">
    <ExhibitionTimeline entries={exhibitions} locale={locale} />
  </section>
</BaseLayout>
