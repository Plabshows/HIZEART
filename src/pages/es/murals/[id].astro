---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../../components/ResponsiveImage.astro";
import ImageGrid from "../../../components/ImageGrid.astro";
import CTASection from "../../../components/CTASection.astro";
import { murals, slugifySegment } from "../../../lib/content";
import { getUiText, localizePath, resolveLocale } from "../../../lib/i18n";

export function getStaticPaths() {
  return murals.map((mural) => ({
    params: { id: mural.slug || slugifySegment(mural.id || mural.title || "mural") },
    props: { mural }
  }));
}

const { mural } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
const ui = getUiText(locale);
const gallery = mural.gallery.map((src) => ({ src, alt: mural.alt }));
const muralImage = new URL(mural.image, "https://hizeart.vercel.app").toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: mural.title,
  creator: "Manuel Forner Hize",
  artMedium: mural.technique,
  locationCreated: mural.location,
  image: muralImage,
  description: mural.description
};
---

<BaseLayout
  title={`${mural.title} | ${locale === "es" ? "Mural de Hize" : "Hize Mural"}`}
  description={mural.description}
  image={mural.image}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={mural.image} alt={mural.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href={localizePath("/murals/", locale)}>{ui.common.backToMurals}</a>
      <p class="eyebrow">{ui.common.muralLabel}</p>
      <h1>{mural.title}</h1>
      <p class="lead">{mural.description}</p>
      <dl class="spec-list">
        <div><dt>{ui.common.year}</dt><dd>{mural.year}</dd></div>
        <div><dt>{ui.common.location}</dt><dd>{mural.location}</dd></div>
        <div><dt>{ui.common.technique}</dt><dd>{mural.technique}</dd></div>
        <div><dt>{ui.common.client}</dt><dd>{mural.client}</dd></div>
      </dl>
      <div class="button-row">
        <a class="button button--primary" href={localizePath("/contact/?type=mural-commission", locale)}>{ui.common.commissionMural}</a>
      </div>
    </div>
  </article>

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{ui.common.muralVisuals}</p>
          <h2>{mural.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} locale={locale} />
    </section>
  )}

  <CTASection
    locale={locale}
    title="Encarga una obra mural específica para el espacio."
    text="Para colecciones privadas, espacios hospitality, proyectos culturales, marcas y muros públicos."
    buttons={[{ href: "/contact/?type=mural-commission", label: ui.common.commissionMural }]}
  />
</BaseLayout>
