---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUiText, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const text = getUiText(locale);
---

<BaseLayout
  title={text.privacy.seoTitle}
  description={text.privacy.seoDescription}
  image="/assets/images/featured/hero-visitacastellon.jpg"
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{text.privacy.eyebrow}</p>
    <h1>{text.privacy.title}</h1>
    <div class="legal-copy">
      {text.privacy.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>
