---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { projects, pages, slugifySegment } from "../lib/content";
import {
  absoluteUrl,
  getLocalizedProjectContent,
  getLocalizedPageContent,
  getUiText,
  localizePath,
  localizeProjectTypeLabel,
  resolveLocale
} from "../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("projects", pages.projects, locale);
const ui = getUiText(locale);
const projectCards = projects.map((project) => ({
  project: getLocalizedProjectContent(project, locale),
  slug: project.slug || slugifySegment(project.id || project.title || "project")
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "es" ? "Proyectos de Hize" : "Projects by Hize",
  url: absoluteUrl(locale === "es" ? "/es/projects/" : "/projects/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="project-hero">
    <ResponsiveImage
      src={page.heroImage}
      alt={page.heroAlt}
      loading="eager"
      sizes="100vw"
    />
    <div class="project-hero__content">
      <p class="eyebrow">{ui.common.projectsEyebrow}</p>
      <h1>{page.heroTitle}</h1>
      <p class="project-hero__intro">
        {page.intro || "Selected case studies across exhibitions, hospitality spaces, brand collaborations, murals and immersive visual experiences."}
      </p>
      <div class="project-hero__rule"></div>
    </div>
  </section>

  <section class="page-shell section projects-index" style="padding-top: 0;">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{ui.common.selectedProjects}</p>
        <h2>{ui.common.projectsHeading}</h2>
      </div>
    </div>

    <div class="projects-index-grid" data-live-collection="projects" data-live-item-type="project" data-live-layout="project-index">
      {projectCards.map(({ project, slug }) => (
        <article class="project-index-card" data-content-id={project.id} data-content-slug={slug}>
          <a class="project-index-card__media" href={localizePath(`/projects/${slug}/`, locale)} aria-label={`${ui.common.viewProject} ${project.title}`}>
            <ResponsiveImage src={project.mainImage} alt={project.alt} />
          </a>
          <div class="project-index-card__body">
            <div class="meta-line">
              <span>{localizeProjectTypeLabel(project.type, locale)}</span>
              <span>{project.year}</span>
            </div>
            <h3><a href={localizePath(`/projects/${slug}/`, locale)}>{project.title}</a></h3>
            <p>{project.description}</p>
            <div class="project-index-card__facts">
              <span>{project.location}</span>
              {project.client && <span>{project.client}</span>}
            </div>
            <a class="text-link" href={localizePath(`/projects/${slug}/`, locale)}>{ui.common.viewProject}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CollectionLiveSync />

  <section class="feature-band" style="text-align: center;">
    <h2>{page.ctaTitle}</h2>
    <div class="button-row" style="justify-content: center;">
      <a class="button" href={localizePath(page.ctaButtonHref, locale)}>{page.ctaButtonLabel}</a>
    </div>
  </section>
</BaseLayout>
