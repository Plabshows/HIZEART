---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { projects, pages, slugifySegment } from "../lib/content";

const page = pages.projects;
const projectCards = projects.map((project) => ({
  project,
  slug: project.slug || slugifySegment(project.id || project.title || "project")
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projects by Hize",
  url: "https://hizeart.vercel.app/projects/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="project-hero">
    <ResponsiveImage
      src={page.heroImage}
      alt={page.heroAlt}
      loading="eager"
      sizes="100vw"
    />
    <div class="project-hero__content">
      <h1>{page.heroTitle}</h1>
      <div class="project-hero__rule"></div>
    </div>
  </section>

  <section class="page-shell section" style="padding-top: 0;">
    <div class="editorial-grid" data-live-collection="projects" data-live-item-type="project">
      {projectCards.map(({ project, slug }) => (
        <article class="editorial-card" data-content-id={project.id} data-content-slug={slug}>
          <a class="editorial-card__media" href={`/projects/${slug}/`}>
            <ResponsiveImage src={project.mainImage} alt={project.alt} />
          </a>
          <div class="card-actions" style="align-items: start;">
            <div>
              <h3><a href={`/projects/${slug}/`}>{project.title}</a></h3>
              <p>{project.description}</p>
            </div>
            <div class="meta-line" style="display: grid; justify-items: end;">
              <span>{project.year} / {project.location}</span>
              <span style="color: var(--secondary);">{project.type}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CollectionLiveSync />

  <section class="feature-band" style="text-align: center;">
    <h2>{page.ctaTitle}</h2>
    <div class="button-row" style="justify-content: center;">
      <a class="button" href={page.ctaButtonHref}>{page.ctaButtonLabel}</a>
    </div>
  </section>
</BaseLayout>
