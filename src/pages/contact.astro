---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { pages } from "../lib/content";

const page = pages.contact;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Hize",
  url: "https://hizeart.vercel.app/contact/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
  </section>

  <section class="page-shell section split-section">
    <div>
      <div class="path-grid" style="grid-template-columns: 1fr;">
        {page.paths.map((path: { eyebrow: string; title: string; text: string }) => (
          <article class="info-card">
            <p class="eyebrow">{path.eyebrow}</p>
            <h3>{path.title === "info@hizeart.com" ? <a href="mailto:info@hizeart.com">{path.title}</a> : path.title}</h3>
            <p>{path.text}</p>
          </article>
        ))}
      </div>
    </div>
    <ContactForm />
  </section>
</BaseLayout>
