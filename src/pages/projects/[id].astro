---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import ImageGrid from "../../components/ImageGrid.astro";
import CTASection from "../../components/CTASection.astro";
import { projects, slugifySegment } from "../../lib/content";
import { getLocalizedProjectContent, getUiText, localizePath, localizeProjectTypeLabel, resolveLocale } from "../../lib/i18n";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.slug || slugifySegment(project.id || project.title || "project") },
    props: { project }
  }));
}

const { project } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
const ui = getUiText(locale);
const localizedProject = getLocalizedProjectContent(project, locale);
const gallery = localizedProject.gallery.map((src) => ({ src, alt: localizedProject.alt }));
const projectImage = new URL(localizedProject.mainImage, "https://hizeart.vercel.app").toString();
const projectVideo = localizedProject.video?.youtubeId
  ? {
      title: localizedProject.video.title || `${localizedProject.title} Film`,
      text: localizedProject.video.text || ui.common.projectFilmFallback,
      youtubeUrl: `https://www.youtube-nocookie.com/embed/${localizedProject.video.youtubeId}?rel=0&modestbranding=1&playsinline=1`,
      watchUrl: `https://www.youtube.com/watch?v=${localizedProject.video.youtubeId}`
    }
  : null;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: localizedProject.title,
  creator: "Manuel Forner Hize",
  locationCreated: localizedProject.location,
  image: projectImage,
  description: localizedProject.description
};
---

<BaseLayout
  title={`${localizedProject.title} | ${locale === "es" ? "Proyecto de Hize" : "Hize Project"}`}
  description={localizedProject.description}
  image={localizedProject.mainImage}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={localizedProject.mainImage} alt={localizedProject.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href={localizePath("/projects/", locale)}>{ui.common.backToProjects}</a>
      <p class="eyebrow">{localizeProjectTypeLabel(localizedProject.type, locale)}</p>
      <h1>{localizedProject.title}</h1>
      <p class="lead">{localizedProject.description}</p>
      <dl class="spec-list">
        <div><dt>{ui.common.year}</dt><dd>{localizedProject.year}</dd></div>
        <div><dt>{ui.common.location}</dt><dd>{localizedProject.location}</dd></div>
        <div><dt>{ui.common.type}</dt><dd>{localizeProjectTypeLabel(localizedProject.type, locale)}</dd></div>
        {localizedProject.client && <div><dt>{ui.common.client}</dt><dd>{localizedProject.client}</dd></div>}
      </dl>
      <div class="button-row">
        <a class="button button--primary" href={localizePath("/contact/", locale)}>{ui.common.startProject}</a>
      </div>
    </div>
  </article>

  {projectVideo && (
    <section class="section project-film">
      <div class="page-shell">
        <div class="section-heading">
          <div>
            <p class="eyebrow">{ui.common.projectFilm}</p>
            <h2>{projectVideo.title}</h2>
          </div>
          <a class="text-link" href={projectVideo.watchUrl} target="_blank" rel="noreferrer">{ui.common.watchOnYouTube}</a>
        </div>
        <div class="project-film__layout">
          <div class="project-film__copy">
            <p class="lead">{projectVideo.text}</p>
            <p class="project-film__meta">{localizedProject.title} / {localizedProject.location} / {localizedProject.year}</p>
          </div>
          <div class="project-film__frame">
            <iframe
              src={projectVideo.youtubeUrl}
              title={`${localizedProject.title} on YouTube`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{ui.common.projectVisuals}</p>
          <h2>{localizedProject.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} locale={locale} />
    </section>
  )}

  <CTASection
    locale={locale}
    title={locale === "es" ? "Inicia un encargo o colaboración." : "Start a commission or collaboration."}
    text={
      locale === "es"
        ? "Comparte el contexto, la ubicación, el calendario y los objetivos para un mural, obra, activación de marca o experiencia visual inmersiva."
        : "Share the context, location, timeline and goals for a mural, artwork, brand activation or immersive visual experience."
    }
    buttons={[{ href: "/contact/", label: ui.common.contactArtist }]}
  />
</BaseLayout>
