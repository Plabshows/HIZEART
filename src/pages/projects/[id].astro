---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import ImageGrid from "../../components/ImageGrid.astro";
import CTASection from "../../components/CTASection.astro";
import { projects, slugifySegment } from "../../lib/content";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.slug || slugifySegment(project.id || project.title || "project") },
    props: { project }
  }));
}

const { project } = Astro.props;
const gallery = project.gallery.map((src) => ({ src, alt: project.alt }));
const projectImage = new URL(project.mainImage, "https://hizeart.vercel.app").toString();
const projectVideo = project.video?.youtubeId
  ? {
      title: project.video.title || `${project.title} Film`,
      text: project.video.text || "A moving portrait of the project, showing the atmosphere and visual rhythm in context.",
      youtubeUrl: `https://www.youtube-nocookie.com/embed/${project.video.youtubeId}?rel=0&modestbranding=1&playsinline=1`,
      watchUrl: `https://www.youtube.com/watch?v=${project.video.youtubeId}`
    }
  : null;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.title,
  creator: "Manuel Forner Hize",
  locationCreated: project.location,
  image: projectImage,
  description: project.description
};
---

<BaseLayout
  title={`${project.title} | Hize Project`}
  description={project.description}
  image={project.mainImage}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={project.mainImage} alt={project.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href="/projects/">Back to Projects</a>
      <p class="eyebrow">{project.type}</p>
      <h1>{project.title}</h1>
      <p class="lead">{project.description}</p>
      <dl class="spec-list">
        <div><dt>Year</dt><dd>{project.year}</dd></div>
        <div><dt>Location</dt><dd>{project.location}</dd></div>
        <div><dt>Type</dt><dd>{project.type}</dd></div>
        <div><dt>Client</dt><dd>{project.client}</dd></div>
      </dl>
      <div class="button-row">
        <a class="button button--primary" href="/contact/">Start a Project</a>
      </div>
    </div>
  </article>

  {projectVideo && (
    <section class="section project-film">
      <div class="page-shell">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Project Film</p>
            <h2>{projectVideo.title}</h2>
          </div>
          <a class="text-link" href={projectVideo.watchUrl} target="_blank" rel="noreferrer">Watch on YouTube</a>
        </div>
        <div class="project-film__layout">
          <div class="project-film__copy">
            <p class="lead">{projectVideo.text}</p>
            <p class="project-film__meta">{project.title} / {project.location} / {project.year}</p>
          </div>
          <div class="project-film__frame">
            <iframe
              src={projectVideo.youtubeUrl}
              title={`${project.title} on YouTube`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Project Visuals</p>
          <h2>{project.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} />
    </section>
  )}

  <CTASection
    title="Start a commission or collaboration."
    text="Share the context, location, timeline and goals for a mural, artwork, brand activation or immersive visual experience."
    buttons={[{ href: "/contact/", label: "Contact the Artist" }]}
  />
</BaseLayout>
