---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import ImageGrid from "../../components/ImageGrid.astro";
import CTASection from "../../components/CTASection.astro";
import { murals } from "../../lib/content";

export function getStaticPaths() {
  return murals.map((mural) => ({
    params: { id: mural.id },
    props: { mural }
  }));
}

const { mural } = Astro.props;
const gallery = mural.gallery.map((src) => ({ src, alt: mural.alt }));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: mural.title,
  creator: "Manuel Forner Hize",
  artMedium: mural.technique,
  locationCreated: mural.location,
  image: `https://hizeart.com${mural.image}`,
  description: mural.description
};
---

<BaseLayout
  title={`${mural.title} | Hize Mural`}
  description={mural.description}
  image={mural.image}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={mural.image} alt={mural.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href="/murals/">Back to Murals</a>
      <p class="eyebrow">Mural</p>
      <h1>{mural.title}</h1>
      <p class="lead">{mural.description}</p>
      <dl class="spec-list">
        <div><dt>Year</dt><dd>{mural.year}</dd></div>
        <div><dt>Location</dt><dd>{mural.location}</dd></div>
        <div><dt>Technique</dt><dd>{mural.technique}</dd></div>
        <div><dt>Client</dt><dd>{mural.client}</dd></div>
      </dl>
      <div class="button-row">
        <a class="button button--primary" href="/contact/?type=mural-commission">Commission a Mural</a>
      </div>
    </div>
  </article>

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Mural Visuals</p>
          <h2>{mural.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} />
    </section>
  )}

  <CTASection
    title="Commission a site-specific wall work."
    text="For private collections, hospitality spaces, cultural projects, brands and public walls."
    buttons={[{ href: "/contact/?type=mural-commission", label: "Commission a Mural" }]}
  />
</BaseLayout>
