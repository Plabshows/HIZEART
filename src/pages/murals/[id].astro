---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import ImageGrid from "../../components/ImageGrid.astro";
import CTASection from "../../components/CTASection.astro";
import { murals, slugifySegment } from "../../lib/content";
import { getLocalizedMuralContent, getUiText, localizePath, resolveLocale } from "../../lib/i18n";

export function getStaticPaths() {
  return murals.map((mural) => ({
    params: { id: mural.slug || slugifySegment(mural.id || mural.title || "mural") },
    props: { mural }
  }));
}

const { mural } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
const ui = getUiText(locale);
const localizedMural = getLocalizedMuralContent(mural, locale);
const gallery = localizedMural.gallery.map((src) => ({ src, alt: localizedMural.alt }));
const muralImage = new URL(localizedMural.image, "https://hizeart.vercel.app").toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: localizedMural.title,
  creator: "Manuel Forner Hize",
  artMedium: localizedMural.technique,
  locationCreated: localizedMural.location,
  image: muralImage,
  description: localizedMural.description
};
---

<BaseLayout
  title={`${localizedMural.title} | ${locale === "es" ? "Mural de Hize" : "Hize Mural"}`}
  description={localizedMural.description}
  image={localizedMural.image}
  type="article"
  structuredData={structuredData}
>
  <article class="detail-layout">
    <div class="detail-media">
      <ResponsiveImage src={localizedMural.image} alt={localizedMural.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
    </div>
    <div class="detail-content">
      <a class="text-link" href={localizePath("/murals/", locale)}>{ui.common.backToMurals}</a>
      <p class="eyebrow">{ui.common.muralLabel}</p>
      <h1>{localizedMural.title}</h1>
      <p class="lead">{localizedMural.description}</p>
      <dl class="spec-list">
        <div><dt>{ui.common.year}</dt><dd>{localizedMural.year}</dd></div>
        <div><dt>{ui.common.location}</dt><dd>{localizedMural.location}</dd></div>
        <div><dt>{ui.common.technique}</dt><dd>{localizedMural.technique}</dd></div>
        {localizedMural.client && localizedMural.client !== "Client TBC" && localizedMural.client !== "Cliente por confirmar" && (
          <div><dt>{ui.common.client}</dt><dd>{localizedMural.client}</dd></div>
        )}
      </dl>
      <div class="button-row">
        <a class="button button--primary" href={localizePath("/contact/?type=mural-commission", locale)}>{ui.common.commissionMural}</a>
      </div>
    </div>
  </article>

  {gallery.length > 0 && (
    <section class="page-shell section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{ui.common.muralVisuals}</p>
          <h2>{localizedMural.title}</h2>
        </div>
      </div>
      <ImageGrid images={gallery} locale={locale} />
    </section>
  )}

  <CTASection
    locale={locale}
    title={locale === "es" ? "Encarga una obra mural específica para el espacio." : "Commission a site-specific wall work."}
    text={
      locale === "es"
        ? "Para colecciones privadas, espacios hospitality, proyectos culturales, marcas y muros públicos."
        : "For private collections, hospitality spaces, cultural projects, brands and public walls."
    }
    buttons={[{ href: "/contact/?type=mural-commission", label: ui.common.commissionMural }]}
  />
</BaseLayout>
