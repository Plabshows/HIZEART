---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CTASection from "../components/CTASection.astro";
import { murals } from "../lib/content";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Murals by Hize",
  url: "https://hizeart.com/murals/"
};
---

<BaseLayout
  title="Murals by Hize | Abstract Graffiti & Urban Art"
  description="Large-scale murals and custom wall artworks by Hize for brands, hospitality spaces, private clients and cultural projects."
  image="/assets/images/murals/mural-torreblanca.jpg"
  structuredData={structuredData}
>
  <section class="editorial-hero">
    <div class="editorial-hero__media">
      <ResponsiveImage
        src="/assets/images/murals/mural-torreblanca.jpg"
        alt="Large scale abstract graffiti mural by Hize in Spain"
        loading="eager"
        sizes="100vw"
      />
    </div>
    <h1>Large-scale abstract graffiti murals for brands, interiors, hospitality spaces and cultural projects.</h1>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Selected Murals</p>
    </div>
    <div class="editorial-grid">
      {murals.map((mural) => (
        <article class="editorial-card">
          <a class="editorial-card__media" href={`/murals/${mural.id}/`}>
            <ResponsiveImage src={mural.image} alt={mural.alt} />
          </a>
          <div class="card-actions" style="align-items: start;">
            <div>
              <h3><a href={`/murals/${mural.id}/`}>{mural.title}</a></h3>
              <p class="meta-line">
                <span>{mural.location}</span>
                <span>{mural.year}</span>
                <span>{mural.technique}</span>
              </p>
              {mural.client !== "Client TBC" && <p>{mural.client}</p>}
            </div>
            <a class="text-link" href={`/murals/${mural.id}/`}>View Details</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="feature-band">
    <div class="page-shell split-section split-section--reverse">
      <div>
        <p class="eyebrow">Process & Execution</p>
        <h2>The authority of the avant-garde applied to structural space.</h2>
        <p class="lead">
          Each mural is developed from the identity of the space, combining Hize's graffiti roots with abstract
          composition, colour and movement. The execution balances street-level kinetic energy with the
          disciplined restraint of a gallery installation.
        </p>
        <div class="process-list">
          <span>01. Site Analysis</span>
          <span>02. Conceptual Development</span>
          <span>03. Execution & Integration</span>
        </div>
      </div>
      <ResponsiveImage src="/assets/images/murals/img-2752-mural.jpeg" alt="Spanish urban artist Hize painting large scale mural" />
    </div>
  </section>

  <CTASection
    title="Commission a Mural"
    text="Hotels, restaurants, private villas, brands and cultural spaces."
    buttons={[{ href: "/contact/?type=mural-commission", label: "Start a Conversation" }]}
  />
</BaseLayout>
