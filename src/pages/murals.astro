---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CTASection from "../components/CTASection.astro";
import { murals, pages, slugifySegment } from "../lib/content";

const page = pages.murals;
const muralCards = murals.map((mural) => ({
  mural,
  slug: mural.slug || slugifySegment(mural.id || mural.title || "mural")
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Murals by Hize",
  url: "https://hizeart.vercel.app/murals/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="editorial-hero">
    <div class="editorial-hero__media">
      <ResponsiveImage
        src={page.heroImage}
        alt={page.heroAlt}
        loading="eager"
        sizes="100vw"
      />
    </div>
    <h1>{page.heroTitle}</h1>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{page.selectedEyebrow}</p>
    </div>
    <div class="editorial-grid">
      {muralCards.map(({ mural, slug }) => (
        <article class="editorial-card">
          <a class="editorial-card__media" href={`/murals/${slug}/`}>
            <ResponsiveImage src={mural.image} alt={mural.alt} />
          </a>
          <div class="card-actions" style="align-items: start;">
            <div>
              <h3><a href={`/murals/${slug}/`}>{mural.title}</a></h3>
              <p class="meta-line">
                <span>{mural.location}</span>
                <span>{mural.year}</span>
                <span>{mural.technique}</span>
              </p>
              {mural.client !== "Client TBC" && <p>{mural.client}</p>}
            </div>
            <a class="text-link" href={`/murals/${slug}/`}>View Details</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="feature-band">
    <div class="page-shell split-section split-section--reverse">
      <div>
        <p class="eyebrow">{page.process.eyebrow}</p>
        <h2>{page.process.title}</h2>
        <p class="lead">{page.process.lead}</p>
        <div class="process-list">
          {page.process.steps.map((step: string) => <span>{step}</span>)}
        </div>
      </div>
      <ResponsiveImage src={page.process.image} alt={page.process.alt} />
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    text={page.cta.text}
    buttons={[{ href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel }]}
  />
</BaseLayout>
