---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import CTASection from "../components/CTASection.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { murals, pages, slugifySegment } from "../lib/content";
import { absoluteUrl, getLocalizedMuralContent, getLocalizedPageContent, getUiText, localizePath, resolveLocale } from "../lib/i18n";

const locale = resolveLocale(Astro.url.pathname);
const page = getLocalizedPageContent("murals", pages.murals, locale);
const ui = getUiText(locale);
const muralCards = murals.map((mural) => ({
  mural: getLocalizedMuralContent(mural, locale),
  slug: mural.slug || slugifySegment(mural.id || mural.title || "mural")
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locale === "es" ? "Murales de Hize" : "Murals by Hize",
  url: absoluteUrl(locale === "es" ? "/es/murals/" : "/murals/")
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="editorial-hero">
    <div class="editorial-hero__media">
      <ResponsiveImage
        src={page.heroImage}
        alt={page.heroAlt}
        loading="eager"
        sizes="100vw"
      />
    </div>
    <h1>{page.heroTitle}</h1>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{page.selectedEyebrow}</p>
    </div>
    <div class="editorial-grid" data-live-collection="murals" data-live-item-type="mural">
      {muralCards.map(({ mural, slug }) => (
        <article class={`editorial-card${mural.id === "puerto-visual-intervention" ? " editorial-card--featured" : ""}`} data-content-id={mural.id} data-content-slug={slug}>
          <a class="editorial-card__media" href={localizePath(`/murals/${slug}/`, locale)}>
            <ResponsiveImage src={mural.image} alt={mural.alt} />
          </a>
          <div class="card-actions" style="align-items: start;">
            <div>
              <h3><a href={localizePath(`/murals/${slug}/`, locale)}>{mural.title}</a></h3>
              <p class="meta-line">
                <span>{mural.location}</span>
                <span>{mural.year}</span>
                <span>{mural.technique}</span>
              </p>
              {mural.client && mural.client !== "Client TBC" && mural.client !== "Cliente por confirmar" && <p>{mural.client}</p>}
            </div>
            <a class="text-link" href={localizePath(`/murals/${slug}/`, locale)}>{ui.common.viewDetails}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CollectionLiveSync />

  <section class="feature-band">
    <div class="page-shell split-section split-section--reverse">
      <div>
        <p class="eyebrow">{page.process.eyebrow}</p>
        <h2>{page.process.title}</h2>
        <p class="lead">{page.process.lead}</p>
        <div class="process-list">
          {page.process.steps.map((step: string) => <span>{step}</span>)}
        </div>
      </div>
      <ResponsiveImage src={page.process.image} alt={page.process.alt} />
    </div>
  </section>

  <CTASection
    locale={locale}
    title={page.cta.title}
    text={page.cta.text}
    buttons={[{ href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel }]}
  />
</BaseLayout>
