---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExhibitionTimeline from "../components/ExhibitionTimeline.astro";
import { exhibitions, pages } from "../lib/content";

const page = pages.exhibitions;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Exhibitions and Collaborations by Hize",
  url: "https://hizeart.vercel.app/exhibitions/"
};
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <section class="page-shell page-intro">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
  </section>
  <section class="page-shell section">
    <ExhibitionTimeline entries={exhibitions} />
  </section>
</BaseLayout>
