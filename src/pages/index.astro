---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import FeaturedWorks from "../components/FeaturedWorks.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CTASection from "../components/CTASection.astro";
import CollectionLiveSync from "../components/CollectionLiveSync.astro";
import { works, projects, collaborations, pages } from "../lib/content";

const page = pages.home;
const featuredWorks = works.filter((work) => work.featured);
const featuredProjects = projects.slice(0, 3);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "HIZE ART",
    url: "https://hizeart.vercel.app"
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Manuel Forner Hize",
    alternateName: "Hize",
    jobTitle: "Spanish contemporary urban artist",
    url: "https://hizeart.vercel.app",
    sameAs: [
      "https://www.instagram.com/hizeart",
      "https://www.facebook.com/hizeart",
      "https://x.com/hizeart"
    ]
  }
];
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  image={page.seoImage}
  structuredData={structuredData}
>
  <Hero
    title={page.hero.title}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    alt={page.hero.alt}
    buttons={[
      { href: page.hero.primaryButtonHref, label: page.hero.primaryButtonLabel },
      { href: page.hero.secondaryButtonHref, label: page.hero.secondaryButtonLabel, variant: "secondary" }
    ]}
  />

  <section class="section split-section">
    <ResponsiveImage
      src={page.artistStatement.image}
      alt={page.artistStatement.alt}
    />
    <div>
      <p class="eyebrow">{page.artistStatement.eyebrow}</p>
      <h2>{page.artistStatement.title}</h2>
      <p class="lead">{page.artistStatement.lead}</p>
      <p>{page.artistStatement.text}</p>
      <a class="text-link" href={page.artistStatement.linkHref}>{page.artistStatement.linkLabel}</a>
    </div>
  </section>

  <section class="section">
    <FeaturedWorks
      works={featuredWorks}
      eyebrow={page.selectedWorks.eyebrow}
      title={page.selectedWorks.title}
      linkLabel={page.selectedWorks.linkLabel}
      linkHref={page.selectedWorks.linkHref}
      categoryFilter="Canvas"
    />
  </section>

  <section class="feature-band">
    <div class="page-shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{page.commissions.eyebrow}</p>
          <h2>{page.commissions.title}</h2>
        </div>
        <a class="text-link" href={page.commissions.linkHref}>{page.commissions.linkLabel}</a>
      </div>
      <p class="lead">{page.commissions.lead}</p>
      <div class="commission-blocks">
        {page.commissions.items.map((item: { title: string; text: string }) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <div class="button-row">
        <a class="button button--primary" href={page.commissions.buttonHref}>{page.commissions.buttonLabel}</a>
      </div>
    </div>
  </section>

  <section class="section split-section">
    <ResponsiveImage
      src={page.vrArt.image}
      alt={page.vrArt.alt}
    />
    <div>
      <p class="eyebrow">{page.vrArt.eyebrow}</p>
      <h2>{page.vrArt.title}</h2>
      <p class="lead">{page.vrArt.lead}</p>
      <a class="text-link" href={page.vrArt.linkHref}>{page.vrArt.linkLabel}</a>
    </div>
  </section>

  <section class="section--dark">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{page.collaborations.eyebrow}</p>
        <h2>{page.collaborations.title}</h2>
      </div>
      <a class="text-link" href={page.collaborations.linkHref}>{page.collaborations.linkLabel}</a>
    </div>
    <div class="logo-strip">
      {collaborations.map((item) => <span>{item.name}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{page.latestProjects.eyebrow}</p>
        <h2>{page.latestProjects.title}</h2>
      </div>
      <a class="text-link" href={page.latestProjects.linkHref}>{page.latestProjects.linkLabel}</a>
    </div>
    <div class="project-grid" data-live-collection="projects" data-live-item-type="project" data-live-limit="3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <CollectionLiveSync />
  </section>

  <CTASection
    title={page.cta.title}
    text={page.cta.text}
    buttons={[
      { href: page.cta.primaryButtonHref, label: page.cta.primaryButtonLabel },
      { href: page.cta.secondaryButtonHref, label: page.cta.secondaryButtonLabel, variant: "secondary" }
    ]}
  />
</BaseLayout>
