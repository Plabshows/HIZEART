---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import FeaturedWorks from "../components/FeaturedWorks.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CTASection from "../components/CTASection.astro";
import { works, projects, collaborations } from "../lib/content";

const featuredWorks = works.filter((work) => work.featured);
const featuredProjects = projects.slice(0, 3);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "HIZE ART",
    url: "https://hizeart.vercel.app"
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Manuel Forner Hize",
    alternateName: "Hize",
    jobTitle: "Spanish contemporary urban artist",
    url: "https://hizeart.vercel.app",
    sameAs: [
      "https://www.instagram.com/hizeart",
      "https://www.facebook.com/hizeart",
      "https://x.com/hizeart"
    ]
  }
];
---

<BaseLayout
  title="Hize Art | Spanish Abstract Graffiti Artist"
  description="Discover Hize, a Spanish visual artist transforming traditional graffiti into abstract paintings, murals and immersive VR art experiences."
  image="/assets/images/canvas/wildsss.jpg"
  structuredData={structuredData}
>
  <Hero
    title="HIZE"
    subtitle="Abstract graffiti born from movement, rhythm and urban memory."
    image="/assets/images/canvas/wildsss.jpg"
    alt="Hize abstract graffiti artwork with sweeping movement and urban rhythm"
    buttons={[
      { href: "/works/", label: "View Works" },
      { href: "/contact/", label: "Commission a Project", variant: "secondary" }
    ]}
  />

  <section class="section split-section">
    <ResponsiveImage
      src="/assets/images/about/hize-art3-portrait.jpg"
      alt="Manuel Forner Hize photographed with abstract graffiti artwork"
    />
    <div>
      <p class="eyebrow">Artist Statement</p>
      <h2>From the street to the studio</h2>
      <p class="lead">
        After more than 25 years painting graffiti, Hize translates the structure of letters,
        movement and urban energy into contemporary abstract compositions.
      </p>
      <p>
        Manuel Forner "Hize" is a Spanish visual artist transforming the language of graffiti
        into abstract paintings, murals and immersive visual experiences.
      </p>
      <a class="text-link" href="/about/">Read the artist profile</a>
    </div>
  </section>

  <section class="section">
    <FeaturedWorks works={featuredWorks} />
  </section>

  <section class="feature-band">
    <div class="page-shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Murals & Commissions</p>
          <h2>Custom artworks and large-scale visual interventions.</h2>
        </div>
        <a class="text-link" href="/murals/">View murals</a>
      </div>
      <p class="lead">
        Custom artworks and large-scale visual interventions for private collections,
        hospitality spaces, brands and cultural projects.
      </p>
      <div class="commission-blocks">
        <article>
          <h3>Private Collectors</h3>
          <p>Original paintings and commissioned works for private collections and interiors.</p>
        </article>
        <article>
          <h3>Brands & Collaborations</h3>
          <p>Visual projects for brands, events and cultural activations with a contemporary art language.</p>
        </article>
        <article>
          <h3>Hospitality & Public Spaces</h3>
          <p>Murals and visual interventions for hotels, restaurants and architectural spaces.</p>
        </article>
      </div>
      <div class="button-row">
        <a class="button button--primary" href="/contact/">Commission a Project</a>
      </div>
    </div>
  </section>

  <section class="section split-section">
    <ResponsiveImage
      src="/assets/images/vr-art/hize-vr-5.jpg"
      alt="Hize VR art performance creating digital graffiti in real time"
    />
    <div>
      <p class="eyebrow">VR Art & Digital Graffiti</p>
      <h2>A digital extension of graffiti.</h2>
      <p class="lead">
        A digital extension of graffiti, where movement, gesture and technology become live visual expression.
      </p>
      <a class="text-link" href="/vr-art/">Explore VR Art</a>
    </div>
  </section>

  <section class="section--dark">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Exhibitions & Collaborations</p>
        <h2>International contexts, cultural projects and premium collaborations.</h2>
      </div>
      <a class="text-link" href="/exhibitions/">View timeline</a>
    </div>
    <div class="logo-strip">
      {collaborations.map((item) => <span>{item.name}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest Projects</p>
        <h2>Selected projects, murals and collaborations.</h2>
      </div>
      <a class="text-link" href="/projects/">View all projects</a>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <CTASection
    title="For artworks, murals, commissions and collaborations."
    text="Request available works, discuss a mural or start a brand, hospitality or cultural project with Hize."
    buttons={[
      { href: "/available-works/", label: "Request Available Works" },
      { href: "/contact/", label: "Contact the Artist", variant: "secondary" }
    ]}
  />
</BaseLayout>
