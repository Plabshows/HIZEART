---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  path?: string;
  type?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const { title, description, image, path, type, structuredData, bodyClass = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#090909" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/assets/icons/hize-favicon.png" />
    <SEOHead title={title} description={description} image={image} path={path} type={type} structuredData={structuredData} />
  </head>
  <body class={bodyClass}>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
