---
import { localizeProjectTypeLabel, type Locale } from "../lib/i18n";

interface Entry {
  year: string;
  title: string;
  type: string;
  location: string;
  description?: string;
}

interface Props {
  entries: Entry[];
  locale?: Locale;
}

const { entries, locale = "en" } = Astro.props;
---

<div class="timeline">
  {entries.map((entry) => (
    <article class="timeline-item">
      <time>{entry.year}</time>
      <div>
        <p class="meta-line"><span>{localizeProjectTypeLabel(entry.type, locale)}</span><span>{entry.location}</span></p>
        <h3>{entry.title}</h3>
        {entry.description && <p>{entry.description}</p>}
      </div>
    </article>
  ))}
</div>
