---
import { getLocalizedExhibitionContent, localizeProjectTypeLabel, type Locale } from "../lib/i18n";

interface Entry {
  year: string;
  title: string;
  type: string;
  location: string;
  description?: string;
}

interface Props {
  entries: Entry[];
  locale?: Locale;
}

const { entries, locale = "en" } = Astro.props;
---

<div class="timeline">
  {entries.map((entry) => {
    const localizedEntry = getLocalizedExhibitionContent(entry, locale);
    return (
    <article class="timeline-item">
      <time>{localizedEntry.year}</time>
      <div>
        <p class="meta-line"><span>{localizeProjectTypeLabel(localizedEntry.type, locale)}</span><span>{localizedEntry.location}</span></p>
        <h3>{localizedEntry.title}</h3>
        {localizedEntry.description && <p>{localizedEntry.description}</p>}
      </div>
    </article>
    );
  })}
</div>
