---
import ResponsiveImage from "./ResponsiveImage.astro";
import { slugifySegment } from "../lib/content";
import {
  getUiText,
  getLocalizedWorkContent,
  localizeAvailabilityLabel,
  localizeCategoryLabel,
  localizePath,
  type Locale
} from "../lib/i18n";

interface Props {
  work: {
    id: string;
    slug?: string;
    title: string;
    year: string;
    category: string;
    technique: string;
    size: string;
    availability: string;
    image: string;
    alt: string;
    href?: string;
  };
  showDetails?: boolean;
  ctaLabel?: string;
  locale?: Locale;
}

const { work, showDetails = false, ctaLabel = "Enquire", locale = "en" } = Astro.props;
const localizedWork = getLocalizedWorkContent(work, locale);
const ui = getUiText(locale);
const category = localizedWork.category.toLowerCase().replace(/\s+/g, "-");
const availability = localizedWork.availability.toLowerCase();
const workSlug = localizedWork.slug || slugifySegment(localizedWork.id || localizedWork.title || "work");
const detailHref = localizePath(localizedWork.href || `/works/${workSlug}/`, locale);
const ctaHref =
  ctaLabel === "View Work"
    || ctaLabel === "Ver obra"
    ? detailHref
    : localizePath(`/contact/?work=${encodeURIComponent(localizedWork.slug || localizedWork.id || workSlug)}`, locale);
const displayCategory = localizeCategoryLabel(localizedWork.category, locale);
const displayAvailability = localizeAvailabilityLabel(localizedWork.availability, locale);
---

<article class="work-card" data-filter-item data-category={category} data-availability={availability} data-content-id={localizedWork.id} data-content-slug={workSlug}>
  <a class="work-card__image" href={detailHref} aria-label={`${ui.common.viewWork} ${localizedWork.title}`}>
    <ResponsiveImage src={localizedWork.image} alt={localizedWork.alt} />
  </a>
  <div class="work-card__body">
    <div class="meta-line">
      <span>{displayCategory}</span>
      <span>{localizedWork.year}</span>
    </div>
    <h3><a href={detailHref}>{localizedWork.title}</a></h3>
    {showDetails && (
      <dl class="compact-specs">
        <div>
          <dt>{ui.common.technique}</dt>
          <dd>{localizedWork.technique}</dd>
        </div>
        <div>
          <dt>{ui.common.size}</dt>
          <dd>{localizedWork.size}</dd>
        </div>
      </dl>
    )}
    <div class="card-actions">
      <span class="status-pill">{displayAvailability}</span>
      <a class="text-link" href={ctaHref}>{ctaLabel}</a>
    </div>
  </div>
</article>
