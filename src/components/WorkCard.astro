---
import ResponsiveImage from "./ResponsiveImage.astro";
import { slugifySegment } from "../lib/content";
import {
  getUiText,
  localizeAvailabilityLabel,
  localizeCategoryLabel,
  localizePath,
  type Locale
} from "../lib/i18n";

interface Props {
  work: {
    id: string;
    slug?: string;
    title: string;
    year: string;
    category: string;
    technique: string;
    size: string;
    availability: string;
    image: string;
    alt: string;
    href?: string;
  };
  showDetails?: boolean;
  ctaLabel?: string;
  locale?: Locale;
}

const { work, showDetails = false, ctaLabel = "Enquire", locale = "en" } = Astro.props;
const ui = getUiText(locale);
const category = work.category.toLowerCase().replace(/\s+/g, "-");
const availability = work.availability.toLowerCase();
const workSlug = work.slug || slugifySegment(work.id || work.title || "work");
const detailHref = localizePath(work.href || `/works/${workSlug}/`, locale);
const ctaHref =
  ctaLabel === "View Work"
    || ctaLabel === "Ver obra"
    ? detailHref
    : localizePath(`/contact/?work=${encodeURIComponent(work.slug || work.id || workSlug)}`, locale);
const displayCategory = localizeCategoryLabel(work.category, locale);
const displayAvailability = localizeAvailabilityLabel(work.availability, locale);
---

<article class="work-card" data-filter-item data-category={category} data-availability={availability} data-content-id={work.id} data-content-slug={workSlug}>
  <a class="work-card__image" href={detailHref} aria-label={`${ui.common.viewWork} ${work.title}`}>
    <ResponsiveImage src={work.image} alt={work.alt} />
  </a>
  <div class="work-card__body">
    <div class="meta-line">
      <span>{displayCategory}</span>
      <span>{work.year}</span>
    </div>
    <h3><a href={detailHref}>{work.title}</a></h3>
    {showDetails && (
      <dl class="compact-specs">
        <div>
          <dt>{ui.common.technique}</dt>
          <dd>{work.technique}</dd>
        </div>
        <div>
          <dt>{ui.common.size}</dt>
          <dd>{work.size}</dd>
        </div>
      </dl>
    )}
    <div class="card-actions">
      <span class="status-pill">{displayAvailability}</span>
      <a class="text-link" href={ctaHref}>{ctaLabel}</a>
    </div>
  </div>
</article>
