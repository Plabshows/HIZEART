---
import ResponsiveImage from "./ResponsiveImage.astro";
import ImageGrid from "./ImageGrid.astro";

interface Props {
  item: {
    title: string;
    year: string;
    category?: string;
    technique?: string;
    size?: string;
    availability?: string;
    price?: string;
    type?: string;
    description: string;
    image?: string;
    mainImage?: string;
    gallery?: string[];
    alt: string;
  };
  backHref: string;
  backLabel: string;
}

const { item, backHref, backLabel } = Astro.props;
const image = item.image || item.mainImage || "";
const gallery = item.gallery || [];
---

<article class="detail-layout">
  <div class="detail-media">
    <ResponsiveImage src={image} alt={item.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
  </div>
  <div class="detail-content">
    <a class="text-link" href={backHref}>{backLabel}</a>
    <p class="eyebrow">{item.category || item.type || "Project"}</p>
    <h1>{item.title}</h1>
    <p class="lead">{item.description}</p>
    <dl class="spec-list">
      <div><dt>Year</dt><dd>{item.year}</dd></div>
      {item.technique && <div><dt>Technique</dt><dd>{item.technique}</dd></div>}
      {item.size && <div><dt>Size</dt><dd>{item.size}</dd></div>}
      {item.availability && <div><dt>Status</dt><dd>{item.availability}</dd></div>}
      {item.price && <div><dt>Price</dt><dd>{item.price}</dd></div>}
    </dl>
    <div class="button-row">
      <a class="button button--primary" href="/contact/">Enquire</a>
      <a class="button button--secondary" href="/available-works/">Request Catalogue</a>
    </div>
  </div>
</article>

{gallery.length > 0 && (
  <section class="section-shell detail-gallery">
    <div class="section-heading">
      <p class="eyebrow">Gallery</p>
      <h2>Additional views</h2>
    </div>
    <ImageGrid images={gallery.map((src) => ({ src, alt: item.alt }))} />
  </section>
)}
