---
import ResponsiveImage from "./ResponsiveImage.astro";
import ImageGrid from "./ImageGrid.astro";
import {
  getLocalizedProjectContent,
  getLocalizedWorkContent,
  getUiText,
  localizeAvailabilityLabel,
  localizeCategoryLabel,
  localizePath,
  localizeProjectTypeLabel,
  type Locale
} from "../lib/i18n";

interface Props {
  item: {
    title: string;
    year: string;
    category?: string;
    technique?: string;
    size?: string;
    availability?: string;
    price?: string;
    type?: string;
    description: string;
    image?: string;
    mainImage?: string;
    gallery?: string[];
    alt: string;
  };
  backHref: string;
  backLabel: string;
  locale?: Locale;
}

const { item, backHref, backLabel, locale = "en" } = Astro.props;
const localizedItem = item.category
  ? getLocalizedWorkContent(item, locale)
  : item.type
    ? getLocalizedProjectContent(item, locale)
    : item;
const image = localizedItem.image || localizedItem.mainImage || "";
const gallery = localizedItem.gallery || [];
const ui = getUiText(locale);
const displayEyebrow = localizedItem.category
  ? localizeCategoryLabel(localizedItem.category, locale)
  : localizedItem.type
    ? localizeProjectTypeLabel(localizedItem.type, locale)
    : ui.common.projectLabel;
---

<article class="detail-layout">
  <div class="detail-media">
    <ResponsiveImage src={image} alt={localizedItem.alt} loading="eager" sizes="(min-width: 900px) 58vw, 100vw" />
  </div>
  <div class="detail-content">
    <a class="text-link" href={localizePath(backHref, locale)}>{backLabel}</a>
    <p class="eyebrow">{displayEyebrow}</p>
    <h1>{localizedItem.title}</h1>
    <p class="lead">{localizedItem.description}</p>
    <dl class="spec-list">
      <div><dt>{ui.common.year}</dt><dd>{localizedItem.year}</dd></div>
      {localizedItem.technique && <div><dt>{ui.common.technique}</dt><dd>{localizedItem.technique}</dd></div>}
      {localizedItem.size && <div><dt>{ui.common.size}</dt><dd>{localizedItem.size}</dd></div>}
      {localizedItem.availability && <div><dt>{ui.common.status}</dt><dd>{localizeAvailabilityLabel(localizedItem.availability, locale)}</dd></div>}
      {localizedItem.price && <div><dt>{ui.common.price}</dt><dd>{localizedItem.price}</dd></div>}
    </dl>
    <div class="button-row">
      <a class="button button--primary" href={localizePath("/contact/", locale)}>{ui.common.enquire}</a>
      <a class="button button--secondary" href={localizePath("/available-works/", locale)}>{ui.common.requestCatalogue}</a>
    </div>
  </div>
</article>

{gallery.length > 0 && (
  <section class="section-shell detail-gallery">
    <div class="section-heading">
      <p class="eyebrow">{ui.common.gallery}</p>
      <h2>{ui.common.additionalViews}</h2>
    </div>
    <ImageGrid images={gallery.map((src) => ({ src, alt: localizedItem.alt }))} locale={locale} />
  </section>
)}
