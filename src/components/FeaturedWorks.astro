---
import WorkCard from "./WorkCard.astro";
import { slugifySegment } from "../lib/content";

interface Work {
  id: string;
  title: string;
  year: string;
  category: string;
  technique: string;
  size: string;
  availability: string;
  image: string;
  alt: string;
}

interface Props {
  works: Work[];
  eyebrow?: string;
  title?: string;
  linkLabel?: string;
  linkHref?: string;
  categoryFilter?: string;
}

const {
  works,
  eyebrow = "Selected Works",
  title = "Abstract graffiti transformed into contemporary visual language.",
  linkLabel = "View all works",
  linkHref = "/works/",
  categoryFilter = ""
} = Astro.props;
const categorySlug = categoryFilter ? slugifySegment(categoryFilter, "work") : "";
const displayWorks = categorySlug
  ? works.filter((work) => slugifySegment(work.category || "", "work") === categorySlug).slice(0, 8)
  : works.slice(0, 8);
---

<div class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  <a class="text-link" href={linkHref}>{linkLabel}</a>
</div>
<div
  class="work-grid"
  data-live-collection="works"
  data-live-item-type="work"
  data-live-limit="8"
  data-live-featured-only="true"
  data-live-category-only={categorySlug || undefined}
  data-live-cta-label="View Work"
>
  {displayWorks.map((work) => <WorkCard work={work} ctaLabel="View Work" />)}
</div>
