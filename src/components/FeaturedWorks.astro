---
import WorkCard from "./WorkCard.astro";
import { slugifySegment } from "../lib/content";
import { localizePath, type Locale } from "../lib/i18n";

interface Work {
  id: string;
  title: string;
  year: string;
  category: string;
  technique: string;
  size: string;
  availability: string;
  image: string;
  alt: string;
}

interface Props {
  works: Work[];
  eyebrow?: string;
  title?: string;
  linkLabel?: string;
  linkHref?: string;
  categoryFilter?: string;
  limit?: number;
  locale?: Locale;
}

const {
  works,
  eyebrow = "Selected Works",
  title = "Abstract graffiti transformed into contemporary visual language.",
  linkLabel = "View all works",
  linkHref = "/works/",
  categoryFilter = "",
  limit = 8,
  locale = "en"
} = Astro.props;
const categorySlug = categoryFilter ? slugifySegment(categoryFilter, "work") : "";
const displayWorks = (categorySlug
  ? works.filter((work) => slugifySegment(work.category || "", "work") === categorySlug)
  : works
).slice(0, limit);
---

<div class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  <a class="text-link" href={localizePath(linkHref, locale)}>{linkLabel}</a>
</div>
<div
  class="work-grid"
  data-live-collection="works"
  data-live-item-type="work"
  data-live-limit={limit}
  data-live-category-only={categorySlug || undefined}
  data-live-cta-label={locale === "es" ? "Ver obra" : "View Work"}
>
  {displayWorks.map((work) => <WorkCard work={work} ctaLabel={locale === "es" ? "Ver obra" : "View Work"} locale={locale} />)}
</div>
