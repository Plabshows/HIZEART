---
import WorkCard from "./WorkCard.astro";

interface Work {
  id: string;
  title: string;
  year: string;
  category: string;
  technique: string;
  size: string;
  availability: string;
  image: string;
  alt: string;
}

interface Props {
  works: Work[];
  eyebrow?: string;
  title?: string;
  linkLabel?: string;
  linkHref?: string;
}

const {
  works,
  eyebrow = "Selected Works",
  title = "Abstract graffiti transformed into contemporary visual language.",
  linkLabel = "View all works",
  linkHref = "/works/"
} = Astro.props;
---

<div class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  <a class="text-link" href={linkHref}>{linkLabel}</a>
</div>
<div class="work-grid">
  {works.slice(0, 8).map((work) => <WorkCard work={work} ctaLabel="View Work" />)}
</div>
