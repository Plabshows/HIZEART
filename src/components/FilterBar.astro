---
interface Filter {
  label: string;
  value: string;
}

interface Props {
  filters: Filter[];
}

const { filters } = Astro.props;
const hasAllFilter = filters.some((filter) => filter.value === "all");
---

<div class="filter-bar" role="toolbar" aria-label="Work filters">
  {filters.map((filter, index) => (
    <button
      type="button"
      class="filter-button"
      data-filter-button={filter.value}
      aria-pressed={hasAllFilter && index === 0 ? "true" : "false"}
    >
      {filter.label}
    </button>
  ))}
</div>

<script>
  function setupFilterBar() {
    const buttons = Array.from(document.querySelectorAll<HTMLElement>("[data-filter-button]"));
    if (buttons.length === 0) return;

    const params = new URLSearchParams(window.location.search);
    let activeFilter = params.get("filter") || "all";

    const getItems = () => Array.from(document.querySelectorAll<HTMLElement>("[data-filter-item]"));

    function applyFilter(filter: string) {
      activeFilter = filter;

      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.filterButton === filter));
      });

      getItems().forEach((item) => {
        const category = item.dataset.category;
        const availability = item.dataset.availability;
        const isVisible =
          filter === "all" ||
          category === filter ||
          availability?.includes(filter) ||
          (filter === "available" && availability?.includes("available")) ||
          (filter === "sold" && availability?.includes("sold"));

        item.toggleAttribute("hidden", !isVisible);
      });
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filterButton || "all";
        const url = new URL(window.location.href);
        if (filter === "all") {
          url.searchParams.delete("filter");
        } else {
          url.searchParams.set("filter", filter);
        }
        history.replaceState({}, "", url);
        applyFilter(filter);
      });
    });

    window.addEventListener("collection-sync:updated", () => {
      applyFilter(activeFilter);
    });

    applyFilter(activeFilter);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupFilterBar, { once: true });
  } else {
    setupFilterBar();
  }
</script>
