---
import { getUiText, type Locale } from "../lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const ui = getUiText(locale);
const enquiryTypes = ui.enquiryTypes;

const formspreeEndpoint = "https://formspree.io/f/mzdwezqn";
---

<form
  class="contact-form"
  name="hize-contact"
  action={formspreeEndpoint}
  method="POST"
  data-form-provider="formspree"
>
  <input type="hidden" name="_subject" value="New enquiry from HIZE ART website" />
  <p class="hidden-field">
    <label>Do not fill this out <input name="_gotcha" tabindex="-1" autocomplete="off" /></label>
  </p>
  <label>
    <span>{ui.contactForm.name}</span>
    <input type="text" name="name" autocomplete="name" required />
  </label>
  <label>
    <span>{ui.contactForm.email}</span>
    <input type="email" name="email" autocomplete="email" required />
  </label>
  <label>
    <span>{ui.contactForm.enquiryType}</span>
    <select name="type" required>
      <option value="">{ui.contactForm.selectOption}</option>
      {enquiryTypes.map((type) => <option value={type}>{type}</option>)}
    </select>
  </label>
  <label>
    <span>{ui.contactForm.message}</span>
    <textarea name="message" rows="7" required></textarea>
  </label>
  <button class="button button--primary" type="submit">{ui.contactForm.send}</button>
  <p class="form-fallback">
    {ui.contactForm.fallback}
    <a href="mailto:info@hizeart.com">info@hizeart.com</a>
  </p>
</form>
