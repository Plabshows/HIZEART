---
import { absoluteUrl, localizePath, stripLocaleFromPath, type Locale } from "../lib/i18n";

interface Props {
  title: string;
  description: string;
  image?: string;
  path?: string;
  type?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  locale?: Locale;
}

const {
  title,
  description,
  image = "/assets/images/featured/hero-visitacastellon.jpg",
  path = Astro.url.pathname,
  type = "website",
  structuredData,
  locale = "en"
} = Astro.props;

const site = "https://hizeart.vercel.app";
const canonical = new URL(path, site).toString();
const imageUrl = absoluteUrl(image);
const basePath = stripLocaleFromPath(path);
const englishUrl = absoluteUrl(localizePath(basePath, "en"));
const spanishUrl = absoluteUrl(localizePath(basePath, "es"));
const ogLocale = locale === "es" ? "es_ES" : "en_US";
const jsonLd = structuredData ? JSON.stringify(structuredData) : "";
const showAlternateLocales = !basePath.endsWith(".html") && !basePath.startsWith("/404");
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{showAlternateLocales && <link rel="alternate" hreflang="en" href={englishUrl} />}
{showAlternateLocales && <link rel="alternate" hreflang="es" href={spanishUrl} />}
{showAlternateLocales && <link rel="alternate" hreflang="x-default" href={englishUrl} />}
<meta property="og:locale" content={ogLocale} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="HIZE ART" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
