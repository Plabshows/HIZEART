---
import ResponsiveImage from "./ResponsiveImage.astro";
import { slugifySegment } from "../lib/content";

interface Props {
  project: {
    id: string;
    slug?: string;
    title: string;
    year: string;
    location: string;
    type: string;
    description: string;
    mainImage: string;
    alt: string;
  };
}

const { project } = Astro.props;
const projectSlug = project.slug || slugifySegment(project.id || project.title || "project");
---

<article class="project-card" data-content-id={project.id} data-content-slug={projectSlug}>
  <a class="project-card__image" href={`/projects/${projectSlug}/`} aria-label={`View ${project.title}`}>
    <ResponsiveImage src={project.mainImage} alt={project.alt} />
  </a>
  <div class="project-card__body">
    <div class="meta-line">
      <span>{project.type}</span>
      <span>{project.year}</span>
    </div>
    <h3><a href={`/projects/${projectSlug}/`}>{project.title}</a></h3>
    <p>{project.description}</p>
    <div class="card-actions">
      <span>{project.location}</span>
      <a class="text-link" href={`/projects/${projectSlug}/`}>View Project</a>
    </div>
  </div>
</article>
