---
import ResponsiveImage from "./ResponsiveImage.astro";
import { slugifySegment } from "../lib/content";
import { getLocalizedProjectContent, getUiText, localizePath, localizeProjectTypeLabel, type Locale } from "../lib/i18n";

interface Props {
  project: {
    id: string;
    slug?: string;
    title: string;
    year: string;
    location: string;
    type: string;
    description: string;
    mainImage: string;
    alt: string;
  };
  locale?: Locale;
}

const { project, locale = "en" } = Astro.props;
const localizedProject = getLocalizedProjectContent(project, locale);
const ui = getUiText(locale);
const projectSlug = localizedProject.slug || slugifySegment(localizedProject.id || localizedProject.title || "project");
const detailHref = localizePath(`/projects/${projectSlug}/`, locale);
---

<article class="project-card" data-content-id={localizedProject.id} data-content-slug={projectSlug}>
  <a class="project-card__image" href={detailHref} aria-label={`${ui.common.viewProject} ${localizedProject.title}`}>
    <ResponsiveImage src={localizedProject.mainImage} alt={localizedProject.alt} />
  </a>
  <div class="project-card__body">
    <div class="meta-line">
      <span>{localizeProjectTypeLabel(localizedProject.type, locale)}</span>
      <span>{localizedProject.year}</span>
    </div>
    <h3><a href={detailHref}>{localizedProject.title}</a></h3>
    <p>{localizedProject.description}</p>
    <div class="card-actions">
      <span>{localizedProject.location}</span>
      <a class="text-link" href={detailHref}>{ui.common.viewProject}</a>
    </div>
  </div>
</article>
