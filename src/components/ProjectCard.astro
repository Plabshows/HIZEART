---
import ResponsiveImage from "./ResponsiveImage.astro";
import { slugifySegment } from "../lib/content";
import { getUiText, localizePath, localizeProjectTypeLabel, type Locale } from "../lib/i18n";

interface Props {
  project: {
    id: string;
    slug?: string;
    title: string;
    year: string;
    location: string;
    type: string;
    description: string;
    mainImage: string;
    alt: string;
  };
  locale?: Locale;
}

const { project, locale = "en" } = Astro.props;
const ui = getUiText(locale);
const projectSlug = project.slug || slugifySegment(project.id || project.title || "project");
const detailHref = localizePath(`/projects/${projectSlug}/`, locale);
---

<article class="project-card" data-content-id={project.id} data-content-slug={projectSlug}>
  <a class="project-card__image" href={detailHref} aria-label={`${ui.common.viewProject} ${project.title}`}>
    <ResponsiveImage src={project.mainImage} alt={project.alt} />
  </a>
  <div class="project-card__body">
    <div class="meta-line">
      <span>{localizeProjectTypeLabel(project.type, locale)}</span>
      <span>{project.year}</span>
    </div>
    <h3><a href={detailHref}>{project.title}</a></h3>
    <p>{project.description}</p>
    <div class="card-actions">
      <span>{project.location}</span>
      <a class="text-link" href={detailHref}>{ui.common.viewProject}</a>
    </div>
  </div>
</article>
