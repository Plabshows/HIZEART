---
import ResponsiveImage from "./ResponsiveImage.astro";

interface Props {
  project: {
    id: string;
    title: string;
    year: string;
    location: string;
    type: string;
    description: string;
    mainImage: string;
    alt: string;
  };
}

const { project } = Astro.props;
---

<article class="project-card">
  <a class="project-card__image" href={`/projects/${project.id}/`} aria-label={`View ${project.title}`}>
    <ResponsiveImage src={project.mainImage} alt={project.alt} />
  </a>
  <div class="project-card__body">
    <div class="meta-line">
      <span>{project.type}</span>
      <span>{project.year}</span>
    </div>
    <h3><a href={`/projects/${project.id}/`}>{project.title}</a></h3>
    <p>{project.description}</p>
    <div class="card-actions">
      <span>{project.location}</span>
      <a class="text-link" href={`/projects/${project.id}/`}>View Project</a>
    </div>
  </div>
</article>
